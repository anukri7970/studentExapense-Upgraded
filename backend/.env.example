# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# --- Database ---
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority


# --- Auth ---
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# --- Stellar ---
# Horizon testnet endpoint and friendbot are public; no key needed for these.
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
# Soroban RPC endpoint used to invoke the deployed contract.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Filled in after you deploy the contract (see contracts/README.md).
SEND_FUNDS_CONTRACT_ID=
# The Stellar Asset Contract (SAC) address for native XLM on testnet.
# Generate it with: node src/scripts/getNativeAssetContractId.js
STELLAR_NATIVE_ASSET_CONTRACT_ID=

# --- AI (Gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- Analytics & Monitoring ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
